<Window x:Class="w_finder.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rauncher Settings"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MinWidth="400"
        Background="{DynamicResource PaneBackground}">

    <StackPanel Margin="20">

        <!-- ═══ Appearance ═══ -->
        <TextBlock Text="APPEARANCE"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource SecondaryText}"/>

        <CheckBox x:Name="DarkModeCheck"
                  Content="Dark mode"
                  FontSize="13"
                  Foreground="{DynamicResource PrimaryText}"
                  Margin="0,0,0,4"
                  Checked="DarkModeCheck_Changed"
                  Unchecked="DarkModeCheck_Changed"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource SeparatorBrush}"/>

        <!-- ═══ Export ═══ -->
        <TextBlock Text="EXPORT"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource SecondaryText}"/>

        <TextBlock Text="Default export path for schedule Excel export:"
                   FontSize="12" Margin="0,0,0,6"
                   Foreground="{DynamicResource PrimaryText}"/>

        <DockPanel Margin="0,0,0,4">
            <Button x:Name="BrowseBtn"
                    DockPanel.Dock="Right"
                    Content="Browse..."
                    Padding="12,4" Margin="8,0,0,0"
                    FontSize="12"
                    Click="BrowseBtn_Click"
                    Background="{DynamicResource ListBackground}"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderBrush="{DynamicResource SearchBoxBorder}"/>

            <TextBox x:Name="ExportPathBox"
                     FontSize="12" Padding="6,4"
                     VerticalContentAlignment="Center"
                     Background="{DynamicResource SearchBoxBackground}"
                     Foreground="{DynamicResource PrimaryText}"
                     BorderBrush="{DynamicResource SearchBoxBorder}"/>
        </DockPanel>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource SeparatorBrush}"/>

        <!-- ═══ Family Mode ═══ -->
        <TextBlock Text="FAMILY / PLACE MODE"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"
                   Foreground="{DynamicResource SecondaryText}"/>

        <CheckBox x:Name="FilterPlacedCheck"
                  Content="Only show types already placed in the project"
                  FontSize="13"
                  Foreground="{DynamicResource PrimaryText}"
                  Margin="0,0,0,4"/>

        <TextBlock Text="When enabled, Place mode (> prefix) only shows family types that have at least one instance in the current project."
                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                   Foreground="{DynamicResource InactiveText}"/>

        <Separator Margin="0,16,0,12"
                   Background="{DynamicResource SeparatorBrush}"/>

        <!-- ═══ Buttons ═══ -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Padding="16,6" Margin="0,0,8,0"
                    FontSize="12"
                    Click="CancelBtn_Click"
                    Background="{DynamicResource ListBackground}"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderBrush="{DynamicResource SearchBoxBorder}"/>

            <Button x:Name="SaveBtn"
                    Content="Save"
                    Padding="16,6"
                    FontSize="12" FontWeight="SemiBold"
                    Click="SaveBtn_Click"
                    Background="{DynamicResource SearchBoxBorderFocus}"
                    Foreground="White"
                    BorderBrush="{DynamicResource SearchBoxBorderFocus}"/>
        </StackPanel>

    </StackPanel>
</Window>
