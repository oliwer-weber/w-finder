<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surface colors -->
    <SolidColorBrush x:Key="PaneBackground"       Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ListBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchBoxBackground"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchBoxBorder"       Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SearchBoxBorderFocus"  Color="#80ACE0"/>
    <SolidColorBrush x:Key="SeparatorBrush"        Color="#E0E0E0"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryText"           Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SecondaryText"         Color="#6E6E6E"/>
    <SolidColorBrush x:Key="InactiveText"          Color="#999999"/>
    <SolidColorBrush x:Key="SearchBoxPlaceholder"  Color="#999999"/>

    <!-- Interactive states -->
    <SolidColorBrush x:Key="ItemHoverBackground"   Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ItemSelectedBackground" Color="#D0DEF0"/>
    <SolidColorBrush x:Key="ItemSelectedText"      Color="#1E1E1E"/>

    <!-- Star icon -->
    <SolidColorBrush x:Key="StarActive"            Color="#C8A850"/>
    <SolidColorBrush x:Key="StarInactive"          Color="#BBBBBB"/>

    <!-- Expander -->
    <SolidColorBrush x:Key="ExpanderHeaderText"    Color="#6E6E6E"/>
    <SolidColorBrush x:Key="FavoritesBackground"   Color="#F7F7F7"/>

</ResourceDictionary>
