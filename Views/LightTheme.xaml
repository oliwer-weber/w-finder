<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Oxford Blue Palette — Light Mode -->

    <!-- Surface colors -->
    <SolidColorBrush x:Key="PaneBackground"       Color="#f6f7f9"/>
    <SolidColorBrush x:Key="ListBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchBoxBackground"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchBoxBorder"       Color="#d5d9e2"/>
    <SolidColorBrush x:Key="SearchBoxBorderFocus"  Color="#677890"/>
    <SolidColorBrush x:Key="SeparatorBrush"        Color="#eceef2"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryText"           Color="#343a46"/>
    <SolidColorBrush x:Key="SecondaryText"         Color="#7485a0"/>
    <SolidColorBrush x:Key="InactiveText"          Color="#6b7a90"/>
    <SolidColorBrush x:Key="SearchBoxPlaceholder"  Color="#8695aa"/>
    <SolidColorBrush x:Key="MutedText"             Color="#7485a0"/>
    <SolidColorBrush x:Key="SectionHeaderText"     Color="#7485a0"/>

    <!-- Interactive states -->
    <SolidColorBrush x:Key="ItemHoverBackground"   Color="#eceef2"/>
    <SolidColorBrush x:Key="ItemSelectedBackground" Color="#d5d9e2"/>
    <SolidColorBrush x:Key="ItemSelectedText"      Color="#343a46"/>

    <!-- Star icon -->
    <SolidColorBrush x:Key="StarActive"            Color="#C8A850"/>
    <SolidColorBrush x:Key="StarInactive"          Color="#b1bbc8"/>

    <!-- Expander / Section headers -->
    <SolidColorBrush x:Key="ExpanderHeaderText"    Color="#8695aa"/>
    <SolidColorBrush x:Key="FavoritesBackground"   Color="#f6f7f9"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumb"           Color="#b1bbc8"/>
    <SolidColorBrush x:Key="ScrollThumbHover"      Color="#8695aa"/>

    <!-- Mode pill colors -->
    <SolidColorBrush x:Key="PillText"              Color="#434e61"/>
    <SolidColorBrush x:Key="PillBorder"            Color="#d5d9e2"/>
    <SolidColorBrush x:Key="BrowserPillText"       Color="#8695aa"/>
    <Color x:Key="PlaceAccentColor">#4a7c59</Color>
    <Color x:Key="EditAccentColor">#6b5ea8</Color>
    <Color x:Key="CommandAccentColor">#8a6d3b</Color>
    <Color x:Key="ShebangAccentColor">#4a7c59</Color>
    <Color x:Key="FilterAccentColor">#c9933a</Color>

    <!-- Hint text (empty states) -->
    <SolidColorBrush x:Key="HintText"             Color="#5a6d82"/>
    <SolidColorBrush x:Key="HintKeyText"          Color="#5a6d82"/>

    <!-- Dot leader for section headers -->
    <SolidColorBrush x:Key="DotLeaderBrush"       Color="#d5d9e2"/>

    <!-- Disclosure chevron -->
    <SolidColorBrush x:Key="DisclosureChevron"     Color="#8695aa"/>

</ResourceDictionary>
