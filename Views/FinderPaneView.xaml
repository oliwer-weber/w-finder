<UserControl x:Class="w_finder.Views.FinderPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:w_finder.Views"
             Background="{DynamicResource PaneBackground}"
             FontFamily="Segoe UI"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:EqualityConverter x:Key="EqualityConverter"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacity"/>

        <!-- Flat ListBox style -->
        <Style x:Key="ThemedListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ListBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ListBoxItem with hover/selected states + disclosure chevron reveal -->
        <Style x:Key="ThemedListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource SeparatorBrush}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ItemSelectedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Star toggle button -->
        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource StarInactive}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource StarActive}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Minimal pill scrollbar -->
        <Style x:Key="PillScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="3"
                                Opacity="0.6"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource PillScrollThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal Expander -->
        <Style x:Key="MinimalExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <Path x:Name="Arrow"
                                                      Data="M 0,0 L 4,3.5 L 0,7"
                                                      Stroke="{DynamicResource ExpanderHeaderText}"
                                                      StrokeThickness="1.2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                                <ContentPresenter ContentSource="Content"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              DockPanel.Dock="Bottom"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Search box with mode pill -->
        <Border Grid.Row="0"
                Background="{DynamicResource SearchBoxBackground}"
                BorderBrush="{DynamicResource SearchBoxBorder}"
                BorderThickness="1"
                CornerRadius="2">
            <DockPanel>
                <!-- Mode Pill (inside search box, left side) -->
                <Border x:Name="ModePillBorder"
                        DockPanel.Dock="Left"
                        Margin="4,3,0,3"
                        Padding="3,1,5,1"
                        CornerRadius="2"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource PillBorder}"/>
                        </Style>
                    </Border.Style>
                    <TextBlock x:Name="ModePillTextBlock"
                               Text="{Binding ModePillText}"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource PillText}"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- Search TextBox -->
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryText}"
                         CaretBrush="{DynamicResource PrimaryText}"
                         Padding="6,6"
                         FontSize="13"
                         VerticalAlignment="Center"
                         PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            </DockPanel>
        </Border>

        <!-- Row 1: Status text (minimal) -->
        <TextBlock Grid.Row="1"
                   FontSize="10"
                   Foreground="{DynamicResource MutedText}"
                   Text="{Binding StatusText}"
                   Margin="4,4,4,2"/>

        <!-- Row 2: Browser mode hints (above favorites, close to search bar) -->
        <StackPanel x:Name="BrowserHints" Grid.Row="2" Margin="4,4,4,0"
                    Visibility="Collapsed">
            <TextBlock FontSize="11" Foreground="{DynamicResource HintText}" Margin="0,2">
                <Run Text="Type  "/><Run Text=">" Foreground="{DynamicResource HintKeyText}" FontWeight="SemiBold"/><Run Text="  to place families"/>
            </TextBlock>
            <TextBlock FontSize="11" Foreground="{DynamicResource HintText}" Margin="0,2">
                <Run Text="Type  "/><Run Text=":" Foreground="{DynamicResource HintKeyText}" FontWeight="SemiBold"/><Run Text="  to run commands"/>
            </TextBlock>
        </StackPanel>

        <!-- Row 3: Favorites section -->
        <Border Grid.Row="3"
                Margin="0,4"
                Background="{DynamicResource FavoritesBackground}"
                CornerRadius="2"
                Visibility="{Binding ShowFavorites, Converter={StaticResource BoolToVisibility}}">
            <Expander IsExpanded="True" Margin="4" Style="{StaticResource MinimalExpander}">
                <Expander.Header>
                    <TextBlock Text="FAVORITES"
                               FontSize="10"
                               Foreground="{DynamicResource SectionHeaderText}"/>
                </Expander.Header>
                <ListBox x:Name="FavoritesList"
                         Style="{StaticResource ThemedListBox}"
                         Background="{DynamicResource FavoritesBackground}"
                         ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                         ItemsSource="{Binding Favorites}"
                         SelectedItem="{Binding HighlightedItem, Mode=OneWay}"
                         IsSynchronizedWithCurrentItem="False"
                         MaxHeight="200"
                         SelectionChanged="List_SelectionChanged"
                         MouseDoubleClick="ResultsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button Content="{Binding FavoriteIcon}"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource StarButton}"
                                        Click="ToggleFavorite_Click"
                                        Tag="{Binding}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedText}"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Expander>
        </Border>

        <!-- Row 4: Empty states -->
        <Border x:Name="EmptyStatePanel"
                Grid.Row="4"
                Visibility="Collapsed"
                Margin="4,4">

            <StackPanel>
                <!-- Place/Edit empty state -->
                <StackPanel x:Name="PlaceEmptyState" Visibility="Collapsed">
                    <!-- Category chips -->
                    <TextBlock Text="CATEGORIES"
                               FontSize="10"
                               Foreground="{DynamicResource SectionHeaderText}"
                               Margin="0,8,0,4"/>
                    <WrapPanel x:Name="CategoryChipsPanel" Margin="0,2,0,0">
                        <!-- Populated from code-behind -->
                    </WrapPanel>
                </StackPanel>

                <!-- Command empty state -->
                <StackPanel x:Name="CommandEmptyState" Visibility="Collapsed">
                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorBrush}"
                            Margin="0,8,0,8" Padding="0,0,0,4"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource HintText}" Margin="0,2">
                        <Run Text="Type to search all Revit commands"/>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Row 5: Results list -->
        <ListBox x:Name="ResultsList"
                 Grid.Row="5"
                 Style="{StaticResource ThemedListBox}"
                 ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                 ItemsSource="{Binding Results}"
                 SelectedItem="{Binding HighlightedItem, Mode=OneWay}"
                 IsSynchronizedWithCurrentItem="False"
                 SelectionChanged="List_SelectionChanged"
                 MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <!-- Dot-leader section header -->
                            <Grid Margin="4,8,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="10"
                                           Foreground="{DynamicResource SectionHeaderText}"/>
                                <!-- Dot leader -->
                                <Border Grid.Column="1"
                                        BorderThickness="0,0,0,1"
                                        Margin="6,0,6,3"
                                        VerticalAlignment="Bottom"
                                        Opacity="0.5"
                                        BorderBrush="{DynamicResource DotLeaderBrush}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ItemCount}"
                                           FontSize="10"
                                           Foreground="{DynamicResource SectionHeaderText}"/>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <!-- Back row styling -->
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackRow}" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>

                        <!-- Star button (hidden for commands/shebangs/back rows/family summary rows) -->
                        <Button Content="{Binding FavoriteIcon}"
                                DockPanel.Dock="Right"
                                Click="ToggleFavorite_Click"
                                Tag="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="14"
                                Width="28" Height="28"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource StarInactive}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource StarActive}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBackRow}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TypeCount, Converter={StaticResource BoolToOpacity}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Right-aligned category/type label -->
                        <TextBlock Text="{Binding Category}"
                                   DockPanel.Dock="Right"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,4,0"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="120">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBackRow}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TypeCount, Converter={StaticResource BoolToOpacity}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ShortcutKeys, Converter={StaticResource NullToCollapsedConverter}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Keyboard shortcut display (command mode) -->
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource MutedText}"
                                   VerticalAlignment="Center"
                                   Margin="4,0"
                                   Visibility="{Binding ShortcutKeys, Converter={StaticResource NullToCollapsedConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding ShortcutKeys}"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Type count + disclosure chevron (family Stage 1) -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="4,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TypeCount, Converter={StaticResource BoolToOpacity}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding TypeCountLabel}"
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <!-- Disclosure chevron — visible on hover/focus -->
                            <TextBlock Text="&#x203A;"
                                       FontSize="14"
                                       Foreground="{DynamicResource DisclosureChevron}"
                                       VerticalAlignment="Center"
                                       Opacity="0"/>
                        </StackPanel>

                        <!-- Main content -->
                        <StackPanel VerticalAlignment="Center">
                            <!-- Back row: italic muted -->
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource MutedText}"
                                       FontStyle="Italic"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Text" Value="{Binding Name}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBackRow}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Normal item name -->
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryText}"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBackRow}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Quick Action Pill Overlay -->
        <Canvas x:Name="OverlayCanvas" Grid.Row="5" IsHitTestVisible="False"/>
        <Border x:Name="ActionBarPopup"
                Grid.Row="5"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Background="{DynamicResource ListBackground}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="4,3"
                Margin="8,0,8,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Opacity="0.25" ShadowDepth="2"/>
            </Border.Effect>
            <ItemsControl ItemsSource="{Binding ActiveActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="2"
                                Padding="8,3"
                                Margin="0,0,4,0"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.FocusedAction"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Background" Value="{DynamicResource SearchBoxBorderFocus}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Label}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.FocusedAction"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Shortcut, StringFormat=' ({0})'}"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"
                                           Foreground="{DynamicResource MutedText}"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Inline Rename Overlay -->
        <Border x:Name="InlineRenamePopup"
                Grid.Row="5"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed"
                Background="{DynamicResource ListBackground}"
                BorderBrush="{DynamicResource SearchBoxBorderFocus}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="6,4"
                Margin="8,0,8,0">
            <StackPanel>
                <DockPanel Visibility="{Binding IsSheetRename, Converter={StaticResource BoolToVisibility}}">
                    <TextBox x:Name="RenameSheetNumberBox"
                             Width="100"
                             DockPanel.Dock="Left"
                             FontSize="12"
                             Margin="0,0,6,0"
                             Padding="4,3"
                             Background="{DynamicResource SearchBoxBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             CaretBrush="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource SearchBoxBorder}"
                             BorderThickness="1"
                             Text="{Binding RenameSheetNumber, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="RenameBox_PreviewKeyDown"/>
                    <TextBox x:Name="RenameSheetNameBox"
                             FontSize="12"
                             Padding="4,3"
                             Background="{DynamicResource SearchBoxBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             CaretBrush="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource SearchBoxBorder}"
                             BorderThickness="1"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="RenameBox_PreviewKeyDown"/>
                </DockPanel>
                <TextBox x:Name="RenameBox"
                         FontSize="12"
                         Padding="4,3"
                         Background="{DynamicResource SearchBoxBackground}"
                         Foreground="{DynamicResource PrimaryText}"
                         CaretBrush="{DynamicResource PrimaryText}"
                         BorderBrush="{DynamicResource SearchBoxBorder}"
                         BorderThickness="1"
                         Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="RenameBox_PreviewKeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSheetRename}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </Border>

        <!-- Inline Error Overlay -->
        <Border x:Name="InlineErrorPopup"
                Grid.Row="5"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Background="#E6860A"
                CornerRadius="2"
                Padding="8,4"
                Margin="8,0,8,0">
            <TextBlock Text="{Binding InlineError}"
                       FontSize="11"
                       Foreground="White"/>
        </Border>
    </Grid>

</UserControl>
