<UserControl x:Class="w_finder.Views.FinderPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:w_finder.Views"
             Background="{DynamicResource PaneBackground}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:EqualityConverter x:Key="EqualityConverter"/>

        <!-- Flat ListBox style (no border, themed background) -->
        <Style x:Key="ThemedListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ListBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- ListBoxItem with hover/selected states -->
        <Style x:Key="ThemedListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource SeparatorBrush}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ItemSelectedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Star toggle button -->
        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource StarInactive}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource StarActive}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SearchBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBoxBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                x:Name="border">
                            <Grid>
                                <!-- Placeholder text -->
                                <TextBlock x:Name="Placeholder"
                                           Text="Search views, sheets, families..."
                                           Foreground="{DynamicResource SearchBoxPlaceholder}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="2,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{DynamicResource SearchBoxBorderFocus}"/>
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme toggle button -->
        <Style x:Key="ThemeToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="ToolTip" Value="Toggle light/dark mode"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal Expander with thin chevron arrow -->
        <Style x:Key="MinimalExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <Path x:Name="Arrow"
                                                      Data="M 0,0 L 4,3.5 L 0,7"
                                                      Stroke="{DynamicResource ExpanderHeaderText}"
                                                      StrokeThickness="1.2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                                <ContentPresenter ContentSource="Content"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              DockPanel.Dock="Bottom"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal pill scrollbar: thin thumb, no arrows, no track chrome -->
        <Style x:Key="PillScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="3"
                                Opacity="0.6"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource PillScrollThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search row: search box + theme toggle -->
        <DockPanel Grid.Row="0">
            <Button x:Name="ThemeToggleBtn"
                    DockPanel.Dock="Right"
                    Style="{StaticResource ThemeToggleButton}"
                    Content="&#x263C;"
                    Margin="4,0,0,0"
                    Click="ThemeToggle_Click"/>
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource SearchBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>
        </DockPanel>

        <!-- Status bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,6,4,2">
            <Border Background="#3C6EB4"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="0,0,6,0"
                    Visibility="{Binding IsBrowserMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="BROWSER"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <Border Background="{DynamicResource SearchBoxBorderFocus}"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="0,0,6,0"
                    Visibility="{Binding IsPlaceFamilyMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="PLACE"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <Border Background="#8B5CF6"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="0,0,6,0"
                    Visibility="{Binding IsEditFamilyMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="EDIT"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <Border Background="#D08030"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="0,0,6,0"
                    Visibility="{Binding IsCommandMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="CMD"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <Border Background="#22C55E"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="0,0,6,0"
                    Visibility="{Binding IsShebangMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="SHEBANG"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource InactiveText}"
                       Text="{Binding StatusText}"/>
        </StackPanel>

        <!-- Favorites section -->
        <Border Grid.Row="2"
                Margin="0,4"
                Background="{DynamicResource FavoritesBackground}"
                CornerRadius="3"
                Visibility="{Binding ShowFavorites, Converter={StaticResource BoolToVisibility}}">
            <Expander IsExpanded="True" Margin="4" Style="{StaticResource MinimalExpander}">
                <Expander.Header>
                    <TextBlock Text="FAVORITES"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ExpanderHeaderText}"/>
                </Expander.Header>
                <ListBox x:Name="FavoritesList"
                         Style="{StaticResource ThemedListBox}"
                         Background="{DynamicResource FavoritesBackground}"
                         ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                         ItemsSource="{Binding Favorites}"
                         SelectedItem="{Binding HighlightedItem, Mode=OneWay}"
                         IsSynchronizedWithCurrentItem="False"
                         MaxHeight="200"
                         SelectionChanged="List_SelectionChanged"
                         MouseDoubleClick="ResultsList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button Content="{Binding FavoriteIcon}"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource StarButton}"
                                        Click="ToggleFavorite_Click"
                                        Tag="{Binding}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryText}"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Expander>
        </Border>

        <!-- Results list -->
        <ListBox x:Name="ResultsList"
                 Grid.Row="3"
                 Style="{StaticResource ThemedListBox}"
                 ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                 ItemsSource="{Binding Results}"
                 SelectedItem="{Binding HighlightedItem, Mode=OneWay}"
                 IsSynchronizedWithCurrentItem="False"
                 SelectionChanged="List_SelectionChanged"
                 MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ExpanderHeaderText}"
                                       Margin="4,8,4,2"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <Button Content="{Binding FavoriteIcon}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource StarButton}"
                                Click="ToggleFavorite_Click"
                                Tag="{Binding}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryText}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Category}"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryText}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Quick Action Pill Overlay (positioned below selected item) -->
        <Canvas x:Name="OverlayCanvas" Grid.Row="3" IsHitTestVisible="False"/>
        <Border x:Name="ActionBarPopup"
                Grid.Row="3"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Background="{DynamicResource ListBackground}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="4,3"
                Margin="8,0,8,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Opacity="0.25" ShadowDepth="2"/>
            </Border.Effect>
            <ItemsControl ItemsSource="{Binding ActiveActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10"
                                Padding="8,3"
                                Margin="0,0,4,0"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource ItemHoverBackground}"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.FocusedAction"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Background" Value="{DynamicResource SearchBoxBorderFocus}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Label}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.FocusedAction"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Shortcut, StringFormat=' ({0})'}"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Inline Rename Overlay (positioned below selected item) -->
        <Border x:Name="InlineRenamePopup"
                Grid.Row="3"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed"
                Background="{DynamicResource ListBackground}"
                BorderBrush="{DynamicResource SearchBoxBorderFocus}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6,4"
                Margin="8,0,8,0">
            <StackPanel>
                <!-- Sheet rename: two fields -->
                <DockPanel Visibility="{Binding IsSheetRename, Converter={StaticResource BoolToVisibility}}">
                    <TextBox x:Name="RenameSheetNumberBox"
                             Width="100"
                             DockPanel.Dock="Left"
                             FontSize="12"
                             Margin="0,0,6,0"
                             Padding="4,3"
                             Background="{DynamicResource SearchBoxBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             CaretBrush="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource SearchBoxBorder}"
                             BorderThickness="1"
                             Text="{Binding RenameSheetNumber, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="RenameBox_PreviewKeyDown"/>
                    <TextBox x:Name="RenameSheetNameBox"
                             FontSize="12"
                             Padding="4,3"
                             Background="{DynamicResource SearchBoxBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             CaretBrush="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource SearchBoxBorder}"
                             BorderThickness="1"
                             Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="RenameBox_PreviewKeyDown"/>
                </DockPanel>
                <!-- Normal rename: single field -->
                <TextBox x:Name="RenameBox"
                         FontSize="12"
                         Padding="4,3"
                         Background="{DynamicResource SearchBoxBackground}"
                         Foreground="{DynamicResource PrimaryText}"
                         CaretBrush="{DynamicResource PrimaryText}"
                         BorderBrush="{DynamicResource SearchBoxBorder}"
                         BorderThickness="1"
                         Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="RenameBox_PreviewKeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSheetRename}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </Border>

        <!-- Inline Error Overlay (positioned below selected item) -->
        <Border x:Name="InlineErrorPopup"
                Grid.Row="3"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Background="#E6860A"
                CornerRadius="4"
                Padding="8,4"
                Margin="8,0,8,0">
            <TextBlock Text="{Binding InlineError}"
                       FontSize="11"
                       Foreground="White"/>
        </Border>
    </Grid>

</UserControl>
