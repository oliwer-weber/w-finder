<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Oxford Blue Palette — Dark Mode (Revit-native chrome) -->

    <!-- Surface colors -->
    <SolidColorBrush x:Key="PaneBackground"       Color="#3b4453"/>
    <SolidColorBrush x:Key="ListBackground"        Color="#323e4e"/>
    <SolidColorBrush x:Key="SearchBoxBackground"   Color="#2c3440"/>
    <SolidColorBrush x:Key="SearchBoxBorder"       Color="#4a5568"/>
    <SolidColorBrush x:Key="SearchBoxBorderFocus"  Color="#677890"/>
    <SolidColorBrush x:Key="SeparatorBrush"        Color="#2e3847"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="PrimaryText"           Color="#c8d0db"/>
    <SolidColorBrush x:Key="SecondaryText"         Color="#677890"/>
    <SolidColorBrush x:Key="InactiveText"          Color="#526077"/>
    <SolidColorBrush x:Key="SearchBoxPlaceholder"  Color="#526077"/>
    <SolidColorBrush x:Key="MutedText"             Color="#677890"/>
    <SolidColorBrush x:Key="SectionHeaderText"     Color="#5d7080"/>

    <!-- Interactive states (Revit-native blue selection) -->
    <SolidColorBrush x:Key="ItemHoverBackground"   Color="#3b4f5e"/>
    <SolidColorBrush x:Key="ItemSelectedBackground" Color="#3b647e"/>
    <SolidColorBrush x:Key="ItemSelectedBorder"    Color="#3b6a85"/>
    <SolidColorBrush x:Key="ItemSelectedText"      Color="#d5e4ed"/>

    <!-- Star icon -->
    <SolidColorBrush x:Key="StarActive"            Color="#B8A04A"/>
    <SolidColorBrush x:Key="StarInactive"          Color="#434e61"/>

    <!-- Expander / Section headers -->
    <SolidColorBrush x:Key="ExpanderHeaderText"    Color="#677890"/>
    <SolidColorBrush x:Key="FavoritesBackground"   Color="#3b4453"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollThumb"           Color="#4a5870"/>
    <SolidColorBrush x:Key="ScrollThumbHover"      Color="#5a6880"/>

    <!-- Mode pill colors -->
    <SolidColorBrush x:Key="PillText"              Color="#d5d9e2"/>
    <SolidColorBrush x:Key="PillBorder"            Color="#434e61"/>
    <SolidColorBrush x:Key="BrowserPillText"       Color="#5d7080"/>
    <Color x:Key="PlaceAccentColor">#4a7c59</Color>
    <Color x:Key="EditAccentColor">#6b5ea8</Color>
    <Color x:Key="CommandAccentColor">#8a6d3b</Color>
    <Color x:Key="ShebangAccentColor">#4a7c59</Color>

    <!-- Hint text (empty states) -->
    <SolidColorBrush x:Key="HintText"             Color="#526077"/>
    <SolidColorBrush x:Key="HintKeyText"          Color="#677890"/>

    <!-- Dot leader for section headers -->
    <SolidColorBrush x:Key="DotLeaderBrush"       Color="#3a4a5a"/>

    <!-- Disclosure chevron -->
    <SolidColorBrush x:Key="DisclosureChevron"     Color="#677890"/>

</ResourceDictionary>
